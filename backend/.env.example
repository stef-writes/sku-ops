# Scope: backend-local — loaded automatically by config.py for ENV=development and ENV=test.
# Copy to backend/.env and fill in the values you need.
# Docker Compose uses the root .env (see .env.production.example) — not this file.
# ── Environment ────────────────────────────────────────────────────────────────
# development | test | production
ENV=development

# ── Auth provider ─────────────────────────────────────────────────────────────
# Auto-selected by environment: supabase in production, internal in dev/test.
# No flag needed — just set ENV correctly.

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres everywhere. Local dev uses docker-compose.dev.yml (./bin/dev db).
# The dev container exposes Postgres on host port 5433 (5433:5432 mapping).
# For Supabase: use the DIRECT connection (port 5432), NOT the pooler (port 6543).
# asyncpg uses prepared statements which are incompatible with pgbouncer.
DATABASE_URL=postgresql://sku_ops:localdev@localhost:5433/sku_ops
# PG_POOL_MIN=2                  (min pool connections, default 2)
# PG_POOL_MAX=10                 (max pool connections, default 10)
# PG_COMMAND_TIMEOUT=30          (query timeout in seconds, default 30)
# PG_ACQUIRE_TIMEOUT=10          (pool acquire timeout in seconds, default 10)

# ── Schema / migrations ───────────────────────────────────────────────────────
# Schema bootstrap runs automatically on startup (CREATE TABLE IF NOT EXISTS).
# There is no incremental migration system. For schema changes in local dev:
#   1. Edit the relevant {context}/infrastructure/schema.py
#   2. Reset the DB: ./bin/dev db:stop && docker compose -f docker-compose.dev.yml down -v
#   3. Restart: ./bin/dev db && ./bin/dev server
# The schema will be re-applied on the next startup.

# ── Redis ────────────────────────────────────────────────────────────────────
# Required when WORKERS > 1 (event hub, chat sessions, sync locks).
# Optional for single-worker dev — subsystems fall back to in-process memory.
# REDIS_URL=redis://localhost:6379

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# REQUIRED in production. Must not be the default value in production.
#
# IMPORTANT: In production (Supabase auth), JWT_SECRET must be your Supabase
# project's JWT secret (Dashboard > Settings > API > JWT Secret).
# The backend validates Supabase-issued tokens with this secret.
# A random value will reject all Supabase tokens.
#
# JWT_SECRET=your-supabase-jwt-secret-here
JWT_ACCESS_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Comma-separated origins.
# Dev defaults to * (permissive). Production rejects *.
# CORS_ORIGINS=https://your-domain.com
# Optional regex for additional CORS origins (e.g. Vercel preview deploys).
# CORS_ORIGIN_REGEX=https://frontend-.*\.vercel\.app

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Set at least one to enable AI features (assistant, UOM classification, OCR).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...          (used for product search embeddings)

# Model overrides (optional)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5
# AGENT_PRIMARY_MODEL=anthropic:claude-sonnet-4-6
# MODEL_REGISTRY_INFRA_SYNTHESIS=anthropic:claude-haiku-4-5  (workflows, memory)
# EMBEDDING_MODEL=text-embedding-3-small
# AGENT_THINKING_BUDGET=0        (0=off, 5000-16000 for extended thinking)
# SESSION_COST_CAP=2.00          (per-session USD cap, 0=unlimited)

# ── Payments ──────────────────────────────────────────────────────────────────
# STRIPE_API_KEY=sk_test_...
# PAYMENT_ADAPTER=stub           (stub|stripe, auto-detected from key)

# ── Xero OAuth 2.0 ───────────────────────────────────────────────────────────
# Register at developer.xero.com. Redirect URI must match your Xero app config.
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=

# ── Server ────────────────────────────────────────────────────────────────────
# WORKERS=1                      (uvicorn worker count — requires REDIS_URL if > 1)
# XERO_SYNC_HOUR=2               (UTC hour for nightly Xero sync, default 2)

# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=INFO
