# ──────────────────────────────────────────────────────────────────────────────
# Scope: repo-root — consumed by docker-compose.yml and deploy/scripts/deploy.sh.
# Copy to .env and fill in all REQUIRED values before deploying.
# Backend-local native dev uses backend/.env instead.
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
ENV=production

# ── Domain ───────────────────────────────────────────────────────────────────
# Used by deploy.sh to configure Certbot and nginx.
DOMAIN=your-domain.com

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED. Strong random password for Postgres.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# REQUIRED. Server refuses to start if unset or default.
#
# IMPORTANT: For Supabase Auth deployments, this MUST be your Supabase project's
# JWT secret — find it at Dashboard > Settings > API > JWT Secret.
# Do NOT generate a random value; the backend uses this to verify Supabase tokens.
JWT_SECRET=

# Token lifetimes (optional — sensible defaults built in)
# JWT_ACCESS_EXPIRATION_MINUTES=15
# REFRESH_TOKEN_EXPIRATION_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# REQUIRED. Comma-separated allowed origins. Must NOT be "*" in production.
CORS_ORIGINS=https://your-domain.com

# Optional regex for additional CORS origins (applied alongside CORS_ORIGINS).
# Useful for Vercel preview deployments which get unique URLs.
# CORS_ORIGIN_REGEX=https://frontend-.*\.vercel\.app

# ── Frontend URL ─────────────────────────────────────────────────────────────
# REQUIRED when frontend and backend are on separate origins (Railway+Vercel).
# Used for OAuth callback redirects (e.g. Xero).
# FRONTEND_URL=https://app.your-domain.com

# ── Observability ────────────────────────────────────────────────────────────
# Sentry DSN (optional but recommended). Get one at https://sentry.io
# SENTRY_DSN=https://...@sentry.io/...

# Log level (default: INFO)
# LOG_LEVEL=INFO

# Bearer token to protect /metrics endpoint. Recommended in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# METRICS_TOKEN=

# ── Uvicorn workers ──────────────────────────────────────────────────────────
# Number of backend worker processes. Rule of thumb: 2 × CPU cores + 1.
WORKERS=4

# ── Postgres connection pool (optional) ──────────────────────────────────────
# PG_POOL_MIN=2
# PG_POOL_MAX=10

# ── AI / LLM ────────────────────────────────────────────────────────────────
# Set at least one to enable AI features (assistant, UOM classification, OCR).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# Model overrides (optional — defaults are sensible)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5
# AGENT_PRIMARY_MODEL=anthropic:claude-sonnet-4-6
# SESSION_COST_CAP=2.00

# ── Xero OAuth 2.0 ──────────────────────────────────────────────────────────
# Register at developer.xero.com. Leave blank to disable Xero integration.
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=https://your-domain.com/api/xero/callback

# ── Rate Limits (optional — defaults built in) ──────────────────────────────
# RATE_LIMIT_AUTH=10/minute
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_API=120/minute

# ── Frontend / Supabase (baked into JS at build time) ─────────────────────────
# REQUIRED. These must be set BEFORE running `npm run build` in frontend/.
# They cannot be changed after the build — a rebuild is needed.
# Find these at Supabase Dashboard > Settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set when backend API is on a different origin than the frontend.
# Leave blank for same-origin deployments (nginx serves both).
# VITE_BACKEND_URL=https://api.your-domain.com

# ── Backup (used by deploy/scripts/backup-postgres.sh) ───────────────────────
# Local retention in days. Older backups are pruned automatically.
# BACKUP_RETENTION_DAYS=7
